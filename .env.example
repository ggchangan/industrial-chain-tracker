ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGIN=https://industry.ygys30ds.cloud
IMAGE_TAG=latest

# 状态存储：file（默认）或 mysql
STATE_STORE_DRIVER=file
# DATABASE_URL=mysql://industrial_chain:password@127.0.0.1:3306/industrial_chain
MYSQL_STATE_TABLE=industrial_chain_content_state
MYSQL_CONNECTION_LIMIT=5
MYSQL_SSL=false

# 对象存储：当前使用 local；腾讯云 COS 驱动接口已预留
OBJECT_STORAGE_DRIVER=local
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_REGION=ap-shanghai
# COS_BUCKET=
# COS_PUBLIC_BASE_URL=
